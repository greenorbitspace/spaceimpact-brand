---
import BaseLayout from '../layouts/BaseLayout.astro';
import PageHero from '../components/PageHero.astro';
import ColourSwatch from '../components/ColourSwatch.astro';
---

<BaseLayout title="Colours — Space Impact Forum brand">
  <PageHero
    eyebrow="Colour system"
    title="A night sky with a beacon."
    intro="Our palette pairs a deep, credible night sky with one warm signature accent. It is practical, distinctive and built for accessible communication."
  />

  <section class="section">
    <div class="shell">
      <div class="colour-grid">
        <ColourSwatch
          name="Orbit Navy"
          hex="#2f2f3f"
          text="Primary field"
        />
        <ColourSwatch
          name="Steel Blue"
          hex="#42799e"
          text="Trusted support"
        />
        <ColourSwatch
          name="Sea Glass"
          hex="#4dccda"
          text="Signature accent"
          kind="paper"
        />
        <ColourSwatch
          name="Frost"
          hex="#f9fcfc"
          text="Light canvas"
          kind="paper"
        />
        <ColourSwatch
          name="Pale Stone"
          hex="#d8dde2"
          text="Lines & structure"
          kind="paper"
        />
        <ColourSwatch
          name="Cool Grey"
          hex="#acb1b9"
          text="Secondary neutral"
          kind="paper"
        />
      </div>
    </div>
  </section>

  <section class="section" style="background: var(--paper)">
    <div class="shell">
      <div class="section-head">
        <p class="eyebrow">Colour usage</p>
        <h2>Make contrast do the work.</h2>
        <p>
          Orbit Navy is our dominant field; Sea Glass is deliberately scarce and should lead attention, not fill a page. Keep body copy in Ink on Frost wherever possible.
        </p>
      </div>

      <div class="usage">
        <article class="usage-panel do">
          <span class="check">✓</span>
          <h3>Primary pairings</h3>
          <p>
            Frost on Orbit Navy, Ink on Frost, and Frost on Steel Blue form the core accessible combinations.
          </p>
        </article>

        <article class="usage-panel dont">
          <span class="cross">×</span>
          <h3>Avoid low contrast</h3>
          <p>
            Do not set body copy in Cool Grey, or use Sea Glass for small text on light backgrounds.
          </p>
        </article>
      </div>
    </div>
  </section>
</BaseLayout>
